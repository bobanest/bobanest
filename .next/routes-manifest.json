{
  "version": 3,
  "pages404": true,
  "appType": "pages",
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "priority": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "onMatchHeaders": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/api/auth/[...nextauth]",
      "regex": "^/api/auth/(.+?)(?:/)?$",
      "routeKeys": {
        "nxtPnextauth": "nxtPnextauth"
      },
      "namedRegex": "^/api/auth/(?<nxtPnextauth>.+?)(?:/)?$"
    },
    {
      "page": "/products/[id]",
      "regex": "^/products/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/products/(?<nxtPid>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/admin/dashboard",
      "regex": "^/admin/dashboard(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/dashboard(?:/)?$"
    },
    {
      "page": "/admin/login",
      "regex": "^/admin/login(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/login(?:/)?$"
    },
    {
      "page": "/admin/products",
      "regex": "^/admin/products(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/products(?:/)?$"
    },
    {
      "page": "/api/admin/products",
      "regex": "^/api/admin/products(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/admin/products(?:/)?$"
    },
    {
      "page": "/api/cart/checkout-session",
      "regex": "^/api/cart/checkout\\-session(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/cart/checkout\\-session(?:/)?$"
    },
    {
      "page": "/api/debug",
      "regex": "^/api/debug(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/debug(?:/)?$"
    },
    {
      "page": "/api/orders/webhook",
      "regex": "^/api/orders/webhook(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/orders/webhook(?:/)?$"
    },
    {
      "page": "/api/test-db",
      "regex": "^/api/test\\-db(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/test\\-db(?:/)?$"
    },
    {
      "page": "/api/track-location",
      "regex": "^/api/track\\-location(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/track\\-location(?:/)?$"
    },
    {
      "page": "/api/webhook/daily-post",
      "regex": "^/api/webhook/daily\\-post(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/webhook/daily\\-post(?:/)?$"
    },
    {
      "page": "/cart",
      "regex": "^/cart(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/cart(?:/)?$"
    },
    {
      "page": "/catering",
      "regex": "^/catering(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/catering(?:/)?$"
    },
    {
      "page": "/contact",
      "regex": "^/contact(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/contact(?:/)?$"
    },
    {
      "page": "/products",
      "regex": "^/products(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/products(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments",
    "clientParamParsing": false,
    "dynamicRSCPrerender": false
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}