'use client';
import ProtectedRoute from '@/components/ProtectedRoute';
import AdminLayout from '@/components/AdminLayout';
import { useState, useEffect } from 'react';
import axios from 'axios';

export default function AdminPromotions() {
  const [promotions, setPromotions] = useState([]);
  const [form, setForm] = useState({ name: '', type: 'percentage', value: 0, minOrderAmount: 0, isActive: true });
  const [editingId, setEditingId] = useState(null);

  useEffect(() => { fetchPromotions(); }, []);

  const fetchPromotions = async () => {
    const res = await axios.get('/api/admin/promotions');
    setPromotions(res.data);
  };

  const handleSubmit = async (e) => {
    e.preventDefault();
    if (editingId) {
      await axios.put(`/api/admin/promotions?id=${editingId}`, form);
    } else {
      await axios.post('/api/admin/promotions', form);
    }
    setForm({ name: '', type: 'percentage', value: 0, minOrderAmount: 0, isActive: true });
    setEditingId(null);
    fetchPromotions();
  };

  const handleDelete = async (id) => {
    if (confirm('Delete promotion?')) {
      await axios.delete(`/api/admin/promotions?id=${id}`);
      fetchPromotions();
    }
  };

  return (
    <ProtectedRoute>
      <AdminLayout>
        <div className="p-8">
          <h1 className="text-3xl font-bold mb-6">Manage Promotions</h1>
          <form onSubmit={handleSubmit} className="bg-white p-4 rounded shadow mb-8">
            <input type="text" placeholder="Name" value={form.name} onChange={e => setForm({...form, name: e.target.value})} className="border p-2 mr-2" required />
            <select value={form.type} onChange={e => setForm({...form, type: e.target.value})} className="border p-2 mr-2">
              <option value="percentage">Percentage (%)</option>
              <option value="fixed">Fixed Amount ($)</option>
              <option value="free_delivery">Free Delivery</option>
              <option value="bogo">Buy One Get One</option>
              <option value="second_discount">Second Item Discount (%)</option>
            </select>
            <input type="number" step="0.01" placeholder="Value" value={form.value} onChange={e => setForm({...form, value: parseFloat(e.target.value)})} className="border p-2 mr-2" />
            <input type="number" step="0.01" placeholder="Min Order Amount" value={form.minOrderAmount} onChange={e => setForm({...form, minOrderAmount: parseFloat(e.target.value)})} className="border p-2 mr-2" />
            <label><input type="checkbox" checked={form.isActive} onChange={e => setForm({...form, isActive: e.target.checked})} /> Active</label>
            <button type="submit" className="bg-primary text-white px-4 py-2 ml-2">{editingId ? 'Update' : 'Create'}</button>
          </form>
          <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
            {promotions.map(p => (
              <div key={p._id} className="bg-white p-4 rounded shadow">
                <h3 className="font-bold">{p.name} {p.isActive ? '✅' : '❌'}</h3>
                <p>Type: {p.type} | Value: {p.value} | Min: ${p.minOrderAmount}</p>
                <button onClick={() => { setForm(p); setEditingId(p._id); }} className="text-blue-600 mr-2">Edit</button>
                <button onClick={() => handleDelete(p._id)} className="text-red-600">Delete</button>
              </div>
            ))}
          </div>
        </div>
      </AdminLayout>
    </ProtectedRoute>
  );
}