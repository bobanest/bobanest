import mongoose from 'mongoose';

const ModifierOptionSchema = new mongoose.Schema({
  name: String,
  price: { type: Number, default: 0 },
});

const ModifierGroupSchema = new mongoose.Schema({
  name: { type: String, required: true }, // e.g., "Size", "Boba"
  required: { type: Boolean, default: false },
  multiple: { type: Boolean, default: false },
  options: [ModifierOptionSchema],
  applicableProducts: [{ type: mongoose.Schema.Types.ObjectId, ref: 'Product' }], // empty = all
});

export default mongoose.models.ModifierGroup || mongoose.model('ModifierGroup', ModifierGroupSchema);